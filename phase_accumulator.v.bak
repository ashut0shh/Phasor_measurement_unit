module phase_accumulator(
    input wire clk,
    input wire enable,
    input wire [9:0] phase_step,

    output reg [9:0] phase,
    output reg phase_valid
);

always @(posedge clk) begin
    if (enable) begin
        phase <= phase + phase_step;
        phase_valid <= 1'b1;
    end else begin
        phase_valid <= 1'b0;
    end
end

endmodule