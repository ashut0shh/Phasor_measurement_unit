

module frequency_estimator(
    input  wire clk,
    input  wire signed [31:0] phase_in,
    input  wire valid_in,

    output reg signed [31:0] freq_out,
    output reg valid_out
);

reg signed [31:0] phase_prev = 0;

always @(posedge clk) begin
    if(valid_in) begin
        freq_out <= phase_in - phase_prev;
        phase_prev <= phase_in;
        valid_out <= 1'b1;
    end
    else
        valid_out <= 1'b0;
end

endmodule