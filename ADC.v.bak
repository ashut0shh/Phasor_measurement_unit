module adc_capture(
    input wire clk,              // FPGA system clock
    input wire adc_clk,          // ADC sampling clock
    input wire [15:0] adc_data,  // ADC parallel data

    output reg signed [15:0] sample_out,
    output reg sample_valid
);

//adc_clk_domain
reg adc_data_reg;
reg adc_clk_toggle =0;

always @(posedge adc_clk)begin
		adc_data_reg <= adc_data;
		adc_clk_toggle<=~adc_clk_toggle;
end

//cdc

reg sync_0=0;
reg sync_1=0;

always @(posedge clk)begin
	sync_0<=adc_clk_toggle;
	sync_1<=sync_0;
end
//transmission
wire new_sample;
assign new_sample= sync_0^sync_1;

//o/p reg

always @(posedge clk) begin
	sample_valid<=0;
	if (new_sample)begin
		sample_out<=adc_data_reg;
		sample_valid<=1;
	end
end
endmodule